# Copy this file to .env and fill in your key:  cp .env.example .env
# .env is gitignored, so your real key never gets committed.

# Your Anthropic API key (from https://console.anthropic.com → API Keys).
ANTHROPIC_API_KEY=sk...

# Optional — only if you use an OAuth token instead of an API key.
# Don't set both ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN at once.
# ANTHROPIC_AUTH_TOKEN=

# Optional — override where the SQLite DB is stored (defaults to ./search_agent.db).
# DB_PATH=/absolute/path/to/search_agent.db

# Optional — Flask port for local dev (defaults to 5000).
# PORT=5000
