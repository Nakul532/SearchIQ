# Copy this file to .env and fill in your key:  cp .env.example .env
# .env is gitignored, so your real key never gets committed.

# Your Anthropic API key (from https://console.anthropic.com → API Keys).
ANTHROPIC_API_KEY=sk...

# Optional — only if you use an OAuth token instead of an API key.
# Don't set both ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN at once.
# ANTHROPIC_AUTH_TOKEN=

# Optional — override where the SQLite DB is stored (defaults to ./search_agent.db).
# DB_PATH=/absolute/path/to/search_agent.db

# Optional — Flask port for local dev (defaults to 5000).
# PORT=5000

# --- Google sign-in ---------------------------------------------------------
# Create an OAuth 2.0 Client (type: Web application) at
# https://console.cloud.google.com/apis/credentials and add the redirect URI
#   http://localhost:5001/auth/callback   (and your deployed https://.../auth/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Signs the 2-week session cookie. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Required in production; a dev fallback is used (with a warning) if unset.
FLASK_SECRET_KEY=
